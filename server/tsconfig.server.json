{
  "compilerOptions": {
    "target":                         "ES2022",
    "lib":                            ["ES2023"],
    "module":                         "NodeNext",
    "moduleResolution":               "NodeNext",
    "outDir":                         "./dist",
    "rootDir":                        "./",
    "strict":                         true,
    "esModuleInterop":                true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck":                   true,
    "sourceMap":                      true,
    "declaration":                    true,
    "resolveJsonModule":              true
  },
  "include": ["**/*"],
  "exclude": ["node_modules", "dist", "remotion-project"]
}
