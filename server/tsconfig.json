{
  "compilerOptions": {
    "target":                         "ES2022",
    "lib":                            ["ES2023"],
    "module":                         "NodeNext",
    "moduleResolution":               "NodeNext",
    "strict":                         true,
    "esModuleInterop":                true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck":                   true,
    "resolveJsonModule":              true,
    "noEmit":                         true
  },
  "include": ["**/*"],
  "exclude": ["node_modules", "dist", "remotion-project"]
}
