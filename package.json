{
  "name": "giant-animator",
  "version": "1.0.0",
  "description": "GiantAnimator — Servidor de geração de vídeos com Remotion + Gemini",
  "type": "module",
  "main": "electron/main.js",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "tsx watch server/index.ts",
    "start": "tsx server/index.ts",
    "electron:dev": "electron .",
    "tunnel": "concurrently \"npm run dev\" \"npx --yes localtunnel --port 3000\"",
    "tunnel:cf": "concurrently \"npm run dev\" \"npx --yes cloudflared tunnel --url http://localhost:3000 --protocol http2\"",
    "tunnel:safe": "concurrently \"npm run dev\" \"npx serve-handler --port 3000\"",
    "sync": "powershell -ExecutionPolicy Bypass -File scripts/sync.ps1",
    "watch-sync": "powershell -ExecutionPolicy Bypass -File scripts/watch-sync.ps1",
    "prebundle": "node scripts/prebundle.mjs",
    "build:server": "cd server && tsc -p tsconfig.server.json && cd ..",
    "build:electron": "electron-builder --win portable --publish never",
    "build": "exit 0"
  },
  "build": {
    "appId": "com.grupoprimo.giantanimator",
    "productName": "GiantAnimator",
    "asar": false,
    "files": [
      "electron/**/*",
      "server/dist/**/*",
      "server/public/**/*",
      "server/prompts/**/*",
      "server/package.json",
      "remotion-project/**/*",
      "node_modules/**/*",
      "package.json",
      ".env"
    ],
    "extraResources": [
      {
        "from": "dist/remotion-bundle",
        "to": "remotion-bundle"
      }
    ],
    "win": {
      "target": [
        {
          "target": "dir",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "category": "public.app-category.productivity"
    },
    "directories": {
      "output": "dist/electron-out"
    }
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.92.0",
    "@google/genai": "^1.48.0",
    "@google/generative-ai": "^0.24.1",
    "@remotion/bundler": "^4.0.446",
    "@remotion/google-fonts": "^4.0.446",
    "@remotion/renderer": "^4.0.446",
    "@supabase/supabase-js": "^2.105.4",
    "axios": "^1.16.0",
    "chokidar": "^3.6.0",
    "concurrently": "^9.1.0",
    "cors": "^2.8.6",
    "dotenv": "^16.6.1",
    "express": "^4.22.1",
    "groq-sdk": "^1.1.2",
    "localtunnel": "^2.0.2",
    "lodash": "^4.18.1",
    "multer": "^2.1.1",
    "openai": "^6.36.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "remotion": "^4.0.453",
    "sharp": "^0.34.5",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "uuid": "^13.0.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/multer": "^2.1.0",
    "@types/node": "^22.19.17",
    "@types/uuid": "^10.0.0",
    "@types/xlsx": "^0.0.35",
    "electron": "^33.4.11",
    "electron-builder": "^25.1.8"
  }
}
