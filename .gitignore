# ============================================
# GiantAnimator — .gitignore
# ============================================

# --- Ambiente e Segredos ---
.env
.env.*
!.env.example

# --- Dependências ---
node_modules/
**/node_modules/

# --- Arquivos de Runtime ---
input/
output/
shared/input/
shared/output/
history.json
shared/history.json

# --- Vídeos e Imagens geradas ---
*.mp4
*.mov
*.avi
*.png
*.jpg
*.jpeg
!remotion-project/src/**/*.png
!remotion-project/src/**/*.jpg

# --- Remotion Build ---
remotion-project/out/
remotion-project/.cache/
remotion-project/dist/

# --- TypeScript Build ---
dist/
build/
*.js.map
*.d.ts.map
tsconfig.tsbuildinfo

# --- Logs ---
*.log
logs/
npm-debug.log*

# --- Backup de histórico do agente ---
agent-backup/history/

# --- Sistema Operacional ---
.DS_Store
Thumbs.db
desktop.ini

# --- Conhecimento e Treinamento ---
knowledge-base/
*.part

# --- IDEs ---
.vscode/
.idea/
*.swp
*.swo
